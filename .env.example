# Forecast-Audit environment template

# Required by the submission validator and OpenEnv manifest.
HF_TOKEN=hf_xxxxx
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# Used by the baseline runner if you want to call the OpenAI-compatible API directly.
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Optional helper for Docker-based workflows.
IMAGE_NAME=forecast-audit-openenv:latest

# Baseline tuning.
TEMPERATURE=0.0
MAX_TOKENS=220
